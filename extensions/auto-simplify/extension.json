{
  "name": "auto-simplify",
  "version": "1.1.0",
  "description": "Automatic code quality review on agent stop — triggers /simplify when significant file changes detected",
  "platforms": [
    "claude"
  ],
  "category": "automation",
  "ruleFiles": {
    "claude": [
      ".claude/rules/auto-simplify/simplify-extended.md"
    ]
  },
  "tools": {
    "auto-simplify": "tools/auto-simplify"
  },
  "toolFiles": {
    "auto-simplify": [
      ".dev-pomogator/tools/auto-simplify/simplify_stop.ts"
    ]
  },
  "hooks": {
    "claude": {
      "Stop": "npx tsx .dev-pomogator/tools/auto-simplify/simplify_stop.ts"
    }
  }
}
