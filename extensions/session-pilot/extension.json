      ".claude/rules/session-pilot/action-button-injection.md",
      ".claude/rules/session-pilot/claude-projects-encoding.md",
      ".claude/rules/session-pilot/perf-budget.md",
      ".claude/rules/session-pilot/mcp-chrome-only.md"
    ]
  },
  "tools": {
    "session-pilot": "tools/session-pilot"
  },
