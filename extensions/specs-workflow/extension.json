{
  "name": "specs-workflow",
  "version": "1.13.0",
  "description": "Управление спецификациями: 4-фазный workflow (включая Context Analysis), TDD-порядок задач, валидация, автоматический аудит кросс-ссылок, MCP инструменты для research",
  "platforms": [
    "claude"
  ],
  "category": "workflow",
  "commandFiles": {
    "claude": [
      ".claude/commands/create-spec.md"
    ]
  },
  "ruleFiles": {
    "claude": [
      ".claude/rules/specs-workflow/specs-management.md",
      ".claude/rules/specs-workflow/no-mocks-fallbacks.md",
      ".claude/rules/specs-workflow/research-workflow.md",
      ".claude/rules/specs-workflow/specs-validation.md"
    ]
  },
  "tools": {
    "specs-generator": "tools/specs-generator",
    "specs-validator": "tools/specs-validator",
    "steps-validator": "tools/steps-validator",
    "mcp-setup": "tools/mcp-setup"
  },
  "toolFiles": {
    "specs-generator": [
      ".dev-pomogator/tools/specs-generator/README.md",
      ".dev-pomogator/tools/specs-generator/specs-generator-core.mjs",
      ".dev-pomogator/tools/specs-generator/fill-template.ts",
      ".dev-pomogator/tools/specs-generator/list-specs.ts",
      ".dev-pomogator/tools/specs-generator/scaffold-spec.ts",
      ".dev-pomogator/tools/specs-generator/spec-status.ts",
      ".dev-pomogator/tools/specs-generator/validate-spec.ts",
      ".dev-pomogator/tools/specs-generator/audit-spec.ts",
      ".dev-pomogator/tools/specs-generator/analyze-features.ts",
      ".dev-pomogator/tools/specs-generator/templates/ACCEPTANCE_CRITERIA.md.template",
      ".dev-pomogator/tools/specs-generator/templates/DESIGN.md.template",
      ".dev-pomogator/tools/specs-generator/templates/feature.template",
      ".dev-pomogator/tools/specs-generator/templates/FILE_CHANGES.md.template",
      ".dev-pomogator/tools/specs-generator/templates/FR.md.template",
      ".dev-pomogator/tools/specs-generator/templates/NFR.md.template",
      ".dev-pomogator/tools/specs-generator/templates/README.md.template",
      ".dev-pomogator/tools/specs-generator/templates/REQUIREMENTS.md.template",
      ".dev-pomogator/tools/specs-generator/templates/RESEARCH.md.template",
      ".dev-pomogator/tools/specs-generator/templates/SCHEMA.md.template",
      ".dev-pomogator/tools/specs-generator/templates/FIXTURES.md.template",
      ".dev-pomogator/tools/specs-generator/templates/TASKS.md.template",
      ".dev-pomogator/tools/specs-generator/templates/USE_CASES.md.template",
      ".dev-pomogator/tools/specs-generator/templates/USER_STORIES.md.template",
      ".dev-pomogator/tools/specs-generator/templates/CHANGELOG.md.template",
      ".dev-pomogator/tools/specs-generator/templates/AUDIT_REPORT.md.template"
    ],
    "specs-validator": [
      ".dev-pomogator/tools/specs-validator/completeness.ts",
      ".dev-pomogator/tools/specs-validator/matcher.ts",
      ".dev-pomogator/tools/specs-validator/phase-constants.ts",
      ".dev-pomogator/tools/specs-validator/phase-gate.ts",
      ".dev-pomogator/tools/specs-validator/audit-checks.ts",
      ".dev-pomogator/tools/specs-validator/audit-runner.ts",
      ".dev-pomogator/tools/specs-validator/reporter.ts",
      ".dev-pomogator/tools/specs-validator/validate-specs.ts",
      ".dev-pomogator/tools/specs-validator/parsers/feature-parser.ts",
      ".dev-pomogator/tools/specs-validator/parsers/md-parser.ts",
      ".dev-pomogator/tools/specs-validator/parsers/test-parser.ts",
      ".dev-pomogator/tools/specs-validator/parsers/tag-utils.ts"
    ],
    "steps-validator": [
      ".dev-pomogator/tools/steps-validator/analyzer.ts",
      ".dev-pomogator/tools/steps-validator/config.ts",
      ".dev-pomogator/tools/steps-validator/detector.ts",
      ".dev-pomogator/tools/steps-validator/logger.ts",
      ".dev-pomogator/tools/steps-validator/reporter.ts",
      ".dev-pomogator/tools/steps-validator/types.ts",
      ".dev-pomogator/tools/steps-validator/validate-steps.ts",
      ".dev-pomogator/tools/steps-validator/docs/CSHARP_PATTERNS.md",
      ".dev-pomogator/tools/steps-validator/docs/SKIP_SCENARIO_ANALYSIS.md",
      ".dev-pomogator/tools/steps-validator/parsers/csharp-parser.ts",
      ".dev-pomogator/tools/steps-validator/parsers/index.ts",
      ".dev-pomogator/tools/steps-validator/parsers/python-parser.ts",
      ".dev-pomogator/tools/steps-validator/parsers/typescript-parser.ts"
    ],
    "mcp-setup": [
      ".dev-pomogator/tools/mcp-setup/mcp-config.json",
      ".dev-pomogator/tools/mcp-setup/README.md",
      ".dev-pomogator/tools/mcp-setup/setup-mcp.py"
    ]
  },
  "hooks": {
    "claude": {
      "UserPromptSubmit": "npx tsx .dev-pomogator/tools/specs-validator/validate-specs.ts",
      "PreToolUse": {
        "matcher": "Write|Edit",
        "command": "npx tsx .dev-pomogator/tools/specs-validator/phase-gate.ts"
      }
    }
  },
  "postInstall": {
    "claude": {
      "command": "python3 .dev-pomogator/tools/mcp-setup/setup-mcp.py --platform claude",
      "interactive": true,
      "skipInCI": true
    }
  },
  "postUpdate": {
    "claude": {
      "command": "python3 .dev-pomogator/tools/mcp-setup/setup-mcp.py --platform claude",
      "interactive": true,
      "skipInCI": true
    }
  },
  "_hooksNote": "specs-validator and steps-validator hooks defined in cursor/claude sections above"
}
