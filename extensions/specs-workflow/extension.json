  "hooks": {
    "claude": {
      "UserPromptSubmit": "npx tsx .dev-pomogator/tools/specs-validator/validate-specs.ts",
      "PreToolUse": [
        {
          "matcher": "Write|Edit",
          "hooks": [
            { "type": "command", "command": "npx tsx .dev-pomogator/tools/specs-validator/phase-gate.ts" },
            { "type": "command", "command": "npx tsx .dev-pomogator/tools/specs-validator/user-story-form-guard.ts" },
            { "type": "command", "command": "npx tsx .dev-pomogator/tools/specs-validator/task-form-guard.ts" },
            { "type": "command", "command": "npx tsx .dev-pomogator/tools/specs-validator/design-decision-guard.ts" },
            { "type": "command", "command": "npx tsx .dev-pomogator/tools/specs-validator/requirements-chk-guard.ts" },
            { "type": "command", "command": "npx tsx .dev-pomogator/tools/specs-validator/risk-assessment-guard.ts" },
            { "type": "command", "command": "npx tsx .dev-pomogator/tools/specs-validator/extension-json-meta-guard.ts" }
          ]
        }
      ]
    }
  },
  "postInstall": {
    "claude": {
      "command": "python3 .dev-pomogator/tools/mcp-setup/setup-mcp.py --platform claude",
      "interactive": true,
      "skipInCI": true
    }
  },
  "postUpdate": {
    "claude": {
      "command": "python3 .dev-pomogator/tools/mcp-setup/setup-mcp.py --platform claude",
      "interactive": true,
      "skipInCI": true
    }
  },
  "_hooksNote": "specs-validator and steps-validator hooks defined in cursor/claude sections above"
