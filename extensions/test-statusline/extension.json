{
  "name": "test-statusline",
  "version": "2.2.0",
  "description": "Test runner session management, YAML status files, wrapper for test output parsing, and background task guard",
  "platforms": ["claude"],
  "category": "automation",
  "tools": {
    "test-statusline": "tools/test-statusline",
    "bg-task-guard": "tools/bg-task-guard"
  },
  "toolFiles": {
    "test-statusline": [
      ".dev-pomogator/tools/test-statusline/package.json",
      ".dev-pomogator/tools/test-statusline/test_runner_wrapper.cjs",
      ".dev-pomogator/tools/test-statusline/statusline_session_start.ts",
      ".dev-pomogator/tools/test-statusline/status_types.ts"
    ],
    "bg-task-guard": [
      ".dev-pomogator/tools/bg-task-guard/mark-bg-task.sh",
      ".dev-pomogator/tools/bg-task-guard/stop-guard.sh"
    ]
  },
  "hooks": {
    "claude": {
      "SessionStart": "npx tsx .dev-pomogator/tools/test-statusline/statusline_session_start.ts",
      "PostToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "bash .dev-pomogator/tools/bg-task-guard/mark-bg-task.sh"
            }
          ]
        }
      ],
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash .dev-pomogator/tools/bg-task-guard/stop-guard.sh"
            }
          ]
        }
      ]
    }
  },
  "statusLine": {
    "claude": {
      "type": "command",
      "command": "npx -y ccstatusline@latest"
    }
  },
  "envRequirements": [
    {
      "name": "TEST_STATUSLINE_ENABLED",
      "required": false,
      "default": "true",
      "description": "Enable/disable test statusline extension"
    }
  ]
}
