# Copy to .env. All values optional — defaults work for local single-user setup.

# Port the proxy listens on (host:container). Default 3456.
# PROXY_PORT=3456

# Max concurrent SDK sessions (Claude Code subscription rate-limit budget).
# MERIDIAN_MAX_CONCURRENT=10

# Shared secret protecting proxy. ONLY needed if you bind to non-localhost
# (e.g. expose to LAN/Tailscale). For loopback-only setup leave commented.
# MERIDIAN_API_KEY=change-me-to-a-strong-random-string
