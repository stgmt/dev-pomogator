  "platforms": [
    "claude"
  ],
  "category": "infrastructure",
  "skills": {
    "proxy-up": ".claude/skills/proxy-up",
    "use-claude-subscription": ".claude/skills/use-claude-subscription"
  },
  "skillFiles": {
    "proxy-up": [
      ".claude/skills/proxy-up/SKILL.md"
    ],
    "use-claude-subscription": [
      ".claude/skills/use-claude-subscription/SKILL.md"
    ]
  },
  "tools": {
    "claude-subscription-proxy": "tools"
  },
  "toolFiles": {
    "claude-subscription-proxy": [
      ".dev-pomogator/tools/claude-subscription-proxy/Dockerfile",
      ".dev-pomogator/tools/claude-subscription-proxy/docker-compose.yml",
      ".dev-pomogator/tools/claude-subscription-proxy/.env.example",
      ".dev-pomogator/tools/claude-subscription-proxy/scripts/start.sh",
      ".dev-pomogator/tools/claude-subscription-proxy/scripts/start.ps1",
      ".dev-pomogator/tools/claude-subscription-proxy/scripts/stop.sh",
      ".dev-pomogator/tools/claude-subscription-proxy/scripts/stop.ps1",
      ".dev-pomogator/tools/claude-subscription-proxy/scripts/health.sh",
      ".dev-pomogator/tools/claude-subscription-proxy/scripts/health.ps1",
      ".dev-pomogator/tools/claude-subscription-proxy/scripts/install-autostart.ps1"
    ]
  },
  "envRequirements": [],
  "postInstall": {
    "command": "echo 'claude-subscription-proxy installed. Run claude login (once), then bash .dev-pomogator/tools/claude-subscription-proxy/scripts/start.sh'",
    "interactive": false,
    "skipInCI": true
  }
