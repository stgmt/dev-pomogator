{
  "name": "tui-test-runner",
  "version": "1.3.0",
  "description": "Rich 4-tab TUI test runner with Python Textual UI, universal framework adapters, /run-tests skill, and test-guard hook",
  "platforms": [
    "claude"
  ],
  "category": "automation",
  "ruleFiles": {
    "claude": [
      ".claude/rules/tui-test-runner/centralized-test-runner.md"
    ]
  },
  "tools": {
    "tui-test-runner": "tools/tui-test-runner"
  },
  "toolFiles": {
    "tui-test-runner": [
      ".dev-pomogator/tools/tui-test-runner/launcher.ts",
      ".dev-pomogator/tools/tui-test-runner/config.ts",
      ".dev-pomogator/tools/tui-test-runner/dispatch.ts",
      ".dev-pomogator/tools/tui-test-runner/test_runner_wrapper.ts",
      ".dev-pomogator/tools/tui-test-runner/tui_session_start.ts",
      ".dev-pomogator/tools/tui-test-runner/tui_stop.ts",
      ".dev-pomogator/tools/tui-test-runner/test_guard.ts",
      ".dev-pomogator/tools/tui-test-runner/build_guard.ts",
      ".dev-pomogator/tools/tui-test-runner/build-staleness.ts",
      ".dev-pomogator/tools/tui-test-runner/yaml_writer.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/types.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/adapter_base.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/vitest_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/jest_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/pytest_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/dotnet_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/rust_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/go_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/cargo_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/adapters/go_test_adapter.ts",
      ".dev-pomogator/tools/tui-test-runner/tui/pyproject.toml",
      ".dev-pomogator/tools/tui-test-runner/tui/__main__.py",
      ".dev-pomogator/tools/tui-test-runner/tui/app.py",
      ".dev-pomogator/tools/tui-test-runner/tui/models.py",
      ".dev-pomogator/tools/tui-test-runner/tui/yaml_reader.py",
      ".dev-pomogator/tools/tui-test-runner/tui/log_reader.py",
      ".dev-pomogator/tools/tui-test-runner/tui/widgets/tests_tab.py",
      ".dev-pomogator/tools/tui-test-runner/tui/widgets/logs_tab.py",
      ".dev-pomogator/tools/tui-test-runner/tui/widgets/monitoring_tab.py",
      ".dev-pomogator/tools/tui-test-runner/tui/widgets/analysis_tab.py",
      ".dev-pomogator/tools/tui-test-runner/tui/widgets/__init__.py",
      ".dev-pomogator/tools/tui-test-runner/tui/widgets/compact_bar.py",
      ".dev-pomogator/tools/tui-test-runner/tui/widgets/clickable_path.py",
      ".dev-pomogator/tools/tui-test-runner/tui/stop_handler.py",
      ".dev-pomogator/tools/tui-test-runner/tui/state_service.py",
      ".dev-pomogator/tools/tui-test-runner/tui/discovery.py",
      ".dev-pomogator/tools/tui-test-runner/tui/__init__.py",
      ".dev-pomogator/tools/tui-test-runner/tui/analyst/__init__.py",
      ".dev-pomogator/tools/tui-test-runner/tui/analyst/patterns.yaml",
      ".dev-pomogator/tools/tui-test-runner/tui/analyst/patterns.py",
      ".dev-pomogator/tools/tui-test-runner/tui/analyst/code_reader.py",
      ".dev-pomogator/tools/tui-test-runner/tui/analyst/parsers.py",
      ".dev-pomogator/tools/tui-test-runner/tui/analyst/output.py",
      ".dev-pomogator/tools/tui-test-runner/test-monitor.sh"
    ]
  },
  "skills": {
    "run-tests": ".claude/skills/run-tests"
  },
  "skillFiles": {
    "run-tests": [
      ".claude/skills/run-tests/SKILL.md"
    ]
  },
  "hooks": {
    "claude": {
      "SessionStart": "npx tsx .dev-pomogator/tools/tui-test-runner/tui_session_start.ts",
      "Stop": "npx tsx .dev-pomogator/tools/tui-test-runner/tui_stop.ts",
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "npx tsx .dev-pomogator/tools/tui-test-runner/build_guard.ts",
              "timeout": 30
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "npx tsx .dev-pomogator/tools/tui-test-runner/test_guard.ts",
              "timeout": 30
            }
          ]
        }
      ]
    }
  },
  "envRequirements": [
    {
      "name": "TEST_STATUSLINE_ENABLED",
      "required": false,
      "default": "true",
      "description": "Enable/disable the canonical status v2 pipeline"
    },
    {
      "name": "TEST_STATUSLINE_FRAMEWORK",
      "required": false,
      "default": "auto",
      "description": "Framework override for canonical status v2 writer: vitest|jest|pytest|dotnet|rust|go|auto"
    }
  ],
  "dependencies": {
    "binaries": ["python3"],
    "pythonPackages": ["textual"]
  }
}
