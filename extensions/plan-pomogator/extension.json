{
  "name": "plan-pomogator",
  "version": "2.1.0",
  "description": "BREAKING: Two-Stage Plan Presentation — mandatory ## 💬 Простыми словами section first (chat summary before monster plan dialog). Rich markdown планы (emoji заголовки, ### todo blocks, blockquotes) + 5-фазная валидация (deterministic planFilePath, Phase 0 duplicate, Phase 2.5 prompt relevance) + session-isolated prompt cache (per-session_id, task-notification filter) + Phase 5 scope-gate advisory (non-blocking) via _shared/scope-gate-score-diff.ts — surfaces recommendation to run /verify-generic-scope-fix when File Changes table touches guard/policy files (Service.ts / Gate.ts / Policy.ts / etc).",
  "platforms": [
    "claude"
  ],
  "category": "workflow",
  "ruleFiles": {
    "claude": [
      ".claude/rules/plan-pomogator/plan-pomogator.md",
      ".claude/rules/plan-pomogator/plan-freshness.md",
      ".claude/rules/plan-pomogator/proactive-investigation.md",
      ".claude/rules/plan-pomogator/cross-scope-coverage.md",
      ".claude/rules/plan-pomogator/spec-test-sync.md"
    ]
  },
  "tools": {
    "plan-pomogator": "tools/plan-pomogator"
  },
  "toolFiles": {
    "plan-pomogator": [
      ".dev-pomogator/tools/plan-pomogator/README.md",
      ".dev-pomogator/tools/plan-pomogator/mcp-dedupe.plan.md",
      ".dev-pomogator/tools/plan-pomogator/requirements.md",
      ".dev-pomogator/tools/plan-pomogator/template.md",
      ".dev-pomogator/tools/plan-pomogator/validate-plan.ts",
      ".dev-pomogator/tools/plan-pomogator/plan-gate.ts",
      ".dev-pomogator/tools/plan-pomogator/prompt-capture.ts",
      ".dev-pomogator/tools/plan-pomogator/prompt-store.ts",
      ".dev-pomogator/tools/plan-pomogator/fixtures/valid.plan.md",
      ".dev-pomogator/tools/plan-pomogator/test-spec-gate.ts"
    ]
  },
  "hooks": {
    "claude": {
      "PreToolUse": {
        "matcher": "ExitPlanMode",
        "command": "npx tsx .dev-pomogator/tools/plan-pomogator/plan-gate.ts"
      },
      "UserPromptSubmit": {
        "command": "npx tsx .dev-pomogator/tools/plan-pomogator/prompt-capture.ts"
      },
      "Stop": {
        "command": "npx tsx .dev-pomogator/tools/plan-pomogator/test-spec-gate.ts"
      }
    }
  }
}
