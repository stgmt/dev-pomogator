{
  "name": "forbid-root-artifacts",
  "version": "1.0.0",
  "description": "Pre-commit хук для контроля файлов в корне репозитория",
  "platforms": [
    "claude"
  ],
  "category": "workflow",
  "commandFiles": {
    "claude": [
      ".claude/commands/configure-root-artifacts.md"
    ]
  },
  "tools": {
    "forbid-root-artifacts": "tools/forbid-root-artifacts"
  },
  "toolFiles": {
    "forbid-root-artifacts": [
      ".dev-pomogator/tools/forbid-root-artifacts/.root-artifacts.yaml.template",
      ".dev-pomogator/tools/forbid-root-artifacts/check.py",
      ".dev-pomogator/tools/forbid-root-artifacts/configure.py",
      ".dev-pomogator/tools/forbid-root-artifacts/default-whitelist.yaml",
      ".dev-pomogator/tools/forbid-root-artifacts/deps-install.py",
      ".dev-pomogator/tools/forbid-root-artifacts/requirements.txt",
      ".dev-pomogator/tools/forbid-root-artifacts/setup.py"
    ]
  },
  "postInstall": {
    "command": "python3 .dev-pomogator/tools/forbid-root-artifacts/deps-install.py && python3 .dev-pomogator/tools/forbid-root-artifacts/configure.py",
    "interactive": true,
    "skipInCI": true
  }
}
