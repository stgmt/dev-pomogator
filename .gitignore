# session-pilot dev-iteration scratch helpers (worktree-only, not for main repo)
/.dev-pomogator-*.sh
/COMMIT_MSG.txt

# Dependencies
node_modules/

# Build output
dist/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/

# Python
__pycache__/
*.pyc
*.pyo

# Temp files
*.tmp
*.temp

# dev-pomogator runtime (tools, backups)
.dev-pomogator/
# scratch / e2e harness (plugin-install Docker test, logs)
.dev-pomogator-tmp/
# but DO track intentional test fixtures that live under a .dev-pomogator/ path
# (e.g. tui-test-runner user-patterns override) — otherwise fresh clones/CI fail those tests
!tests/fixtures/**/.dev-pomogator/
!tests/fixtures/**/.dev-pomogator/**
# hyperv-test-runner artifacts: .dev-pomogator/hyperv-runs/ (per-run logs + screenshots)
# RDP file (contains VM IP, user-specific)
claude-test.rdp

# OEM offline installers (if cached locally)
oem/*.msi
oem/*.exe
!oem/install.bat

# Windows null device artifact
nul

# .NET build artifacts
*.sln
**/obj/
**/bin/

# Environment files with secrets
.env
.env.*
!.env.example

# strong-tests JiT runtime audit log (suppression entries; per .specs/strong-tests/ NFR-S4)
.claude/logs/strong-tests-skips.jsonl
.claude/logs/
