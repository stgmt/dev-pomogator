# Dependencies
node_modules/

# Build output
dist/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/

# Python
__pycache__/
*.pyc
*.pyo

# Temp files
*.tmp
*.temp

# dev-pomogator runtime (tools, backups)
.dev-pomogator/
# hyperv-test-runner artifacts: .dev-pomogator/hyperv-runs/ (per-run logs + screenshots)
