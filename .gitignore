claude-test.rdp

# OEM offline installers (if cached locally)
oem/*.msi
oem/*.exe
!oem/install.bat

# Windows null device artifact
nul

# .NET build artifacts
*.sln
**/obj/
**/bin/

# Environment files with secrets
.env
.env.*
!.env.example
