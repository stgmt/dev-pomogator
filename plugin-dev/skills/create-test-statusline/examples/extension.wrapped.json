{
  "name": "my-test-statusline",
  "version": "1.0.0",
  "description": "Test runner progress display in Claude Code statusline (with wrapper)",
  "platforms": ["claude"],
  "category": "automation",
  "files": {
    "claude": []
  },
  "tools": {
    "my-test-statusline": "tools/my-test-statusline"
  },
  "toolFiles": {
    "my-test-statusline": [
      ".dev-pomogator/tools/my-test-statusline/statusline_render.cjs",
      ".dev-pomogator/tools/my-test-statusline/test_runner_wrapper.cjs",
      ".dev-pomogator/tools/my-test-statusline/session_start_hook.cjs",
      ".dev-pomogator/tools/my-test-statusline/statusline_wrapper.cjs",
      ".dev-pomogator/tools/my-test-statusline/package.json"
    ]
  },
  "hooks": {
    "claude": {
      "SessionStart": "node .dev-pomogator/tools/my-test-statusline/session_start_hook.cjs"
    }
  },
  "statusLine": {
    "claude": {
      "type": "command",
      "command": "node -e \"require(require('path').join(require('os').homedir(), '.dev-pomogator', 'tools', 'my-test-statusline', 'statusline_wrapper.cjs'))\" --user-b64 REPLACE_WITH_BASE64_USER_CMD --managed-b64 REPLACE_WITH_BASE64_RENDER_CMD"
    }
  },
  "envRequirements": [
    {
      "name": "TEST_STATUSLINE_ENABLED",
      "required": false,
      "default": "true",
      "description": "Enable/disable test statusline extension"
    },
    {
      "name": "TEST_STATUSLINE_FRAMEWORK",
      "required": false,
      "description": "Override framework auto-detection (vitest/jest/pytest/dotnet/rust/go)"
    }
  ]
}
