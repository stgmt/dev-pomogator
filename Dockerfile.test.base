# syntax=docker/dockerfile:1
# Base image for dev-pomogator tests.
# Contains all heavy dependencies (apt, pip, powershell, bun, cursor, claude-mem).
# Rebuild rarely: scripts/build-test-base.sh

FROM node:20-slim

# Install git, python, PowerShell and other dependencies
RUN --mount=type=cache,target=/var/cache/apt \
    apt-get update && apt-get install -y git curl unzip python3 python3-pip python3-yaml wget apt-transport-https software-properties-common jq tini && \
    apt-get clean && rm -rf /var/lib/apt/lists/* && \
    ln -s /usr/bin/python3 /usr/bin/python

# Install Python packages
RUN --mount=type=cache,target=/root/.cache/pip \
    pip3 install --break-system-packages chromadb textual pytest pytest-asyncio

# Install PowerShell Core
RUN wget -q https://packages.microsoft.com/config/debian/12/packages-microsoft-prod.deb && \
    dpkg -i packages-microsoft-prod.deb && \
    rm packages-microsoft-prod.deb && \
    apt-get update && \
    apt-get install -y powershell && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally (as root, before user switch)
RUN npm install -g @anthropic-ai/claude-code || true

# Create test user with home directory
RUN useradd -m -s /bin/bash testuser

# Switch to testuser
USER testuser
ENV HOME=/home/testuser
ENV PATH="${HOME}/.bun/bin:${HOME}/.local/bin:${PATH}"
ENV DEV_POMOGATOR_TEST_IN_DOCKER=1

# Install bun for testuser
RUN curl -fsSL https://bun.sh/install | bash

# Install Cursor Agent CLI
RUN curl -fsSL https://cursor.com/install | bash && \
    cursor-agent --version

# Pre-cache claude-mem clone and build
RUN (for i in 1 2 3; do \
      git clone https://github.com/thedotmack/claude-mem.git \
        /home/testuser/.claude/plugins/marketplaces/thedotmack && break; \
      echo "Clone attempt $i failed, retrying in ${i}0s..."; \
      rm -rf /home/testuser/.claude/plugins/marketplaces/thedotmack; \
      sleep $((i * 10)); \
    done && \
    cd /home/testuser/.claude/plugins/marketplaces/thedotmack && \
    bun install && \
    bun run build) || echo "WARNING: claude-mem pre-cache failed, will clone at runtime"

WORKDIR /home/testuser/app
