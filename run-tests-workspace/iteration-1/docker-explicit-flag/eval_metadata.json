      "description": "Command uses test_runner_wrapper.sh",
      "check": "command.txt contains 'test_runner_wrapper.sh'"
    },
    {
      "name": "uses-vitest-grep",
      "description": "Detects vitest and uses --grep for filter",
      "check": "command.txt contains '--grep'"
    }
  ]
}
