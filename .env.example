# ============================================
# dev-pomogator — environment variables
# Generated by installer. Copy to .env and fill values.
# ============================================

# --- auto-commit ---
# [REQUIRED] API key for LLM commit message generation
AUTO_COMMIT_API_KEY=sk-xxx

# [optional] Custom LLM endpoint (default: aipomogator.ru)
# AUTO_COMMIT_LLM_URL=https://aipomogator.ru/go/v1

# [optional] LLM model name
# AUTO_COMMIT_LLM_MODEL=openrouter/deepseek/deepseek-v3.2

# --- prompt-suggest ---
# [optional] OpenRouter API key for Haiku LLM (priority over AUTO_COMMIT_API_KEY)
# OPENROUTER_API_KEY=sk-or-v1-xxx

# [optional] Fallback API key (aipomogator.ru) if OPENROUTER not set
# AUTO_COMMIT_API_KEY=sk-xxx

# [optional] Enable/disable prompt suggestions (default: true)
# PROMPT_SUGGEST_ENABLED=true

# [optional] Suggestion TTL in ms (default: 600000 = 10 min)
# PROMPT_SUGGEST_TTL=600000

# --- test-statusline ---
# [optional] Enable/disable test statusline extension
# TEST_STATUSLINE_ENABLED=true

# --- canonical status-v2 runtime ---
# [optional] Enable/disable the shared test-statusline + TUI runtime
# TEST_STATUSLINE_ENABLED=true

# [optional] Framework override: vitest|jest|pytest|dotnet|rust|go|auto
# TEST_STATUSLINE_FRAMEWORK=auto
